PORT=3000
NODE_ENV=development

# After changing .env, create tables once:
#   npm run db:migrate
# Check status: npm run db:migrate:status

# JWT for login tokens
JWT_SECRET=replace-with-a-long-random-string

# Option A — single URL (recommended for hosting providers)
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/rafiki_help_me

# Option B — discrete variables
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rafiki_help_me
DB_USER=postgres
DB_PASSWORD=

# Set to true if your provider requires SSL (e.g. some cloud Postgres)
# DB_SSL=false
